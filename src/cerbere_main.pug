include layout/spine
include mixins/utils
include pages/character

.cerbere-main
  header.sheet-header
    h1 Fiche de Personnage

  section.dice-section
    h2 Jets de dés
    .dice-buttons
      button(type="roll", value="Jet 1d10 : [[1d10cs>8]]")
      button(type="roll", value="Jet 2d10 : [[1d10cs>8]] [[1d10cs>8]]")
      button(type="roll", value="Jet 3d10 : [[1d10cs>8]] [[1d10cs>8]] [[1d10cs>8]]")

  section.description-section
    h2 Description du personnage

    input(type="checkbox", class="edit-toggle", name="attr_editmode", id="editmode-toggle", hidden)
    label.toggle-edit(for="editmode-toggle") Mode édition

    +character-view(spine.character)
    +character-edit(spine.character)